# ---------------------------------------------------------------
# UnrealIRCd Admin Panel — configuration
# Copy this to .env and fill in your values.
# The panel reads these as environment variables at startup.
# ---------------------------------------------------------------

# --- UnrealIRCd RPC connection ---
# Must match your rpc-user block in unrealircd.conf
RPC_HOST=127.0.0.1
RPC_PORT=8600
RPC_USER=webpanel
RPC_PASSWORD=changeme

# Set to "false" if using a self-signed cert (common on LAN/local setups)
# Set to "true" if you have a real cert (e.g. Let's Encrypt)
RPC_TLS_VERIFY=false

# --- Panel login ---
# Single-user auth. Change both before deploying.
PANEL_USER=admin
PANEL_PASSWORD=changeme

# Flask session secret — must be a long random string in production.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
PANEL_SECRET=changeme-use-a-long-random-string-here

# --- Display ---
NETWORK_NAME=UnrealIRCd
